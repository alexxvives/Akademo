# PDF Migration — env vars
# Copy this file to scripts/.env and fill in the values.
# scripts/.env is gitignored and never committed.

# ── SiteGround FTP ───────────────────────────────────────────────────────────
FTP_HOST=ftp.your-client-domain.es
FTP_USER=your_ftp_username
FTP_PASS=your_ftp_password
# Set to 1 if the server requires FTPS (FTP over TLS)
FTP_SECURE=0

# ── AKADEMO ──────────────────────────────────────────────────────────────────
# Admin auth token — copy from browser localStorage key "auth_token"
AKADEMO_TOKEN=your_auth_token_here

# Academy ID for the migration target
# Run: SELECT id FROM Academy WHERE name LIKE '%maximo%';  in D1 to find it
AKADEMO_ACADEMY_ID=your_academy_id_here

# API base URL (default is production — change for local dev)
# AKADEMO_API_URL=http://localhost:8787

# ── Class map override (optional) ────────────────────────────────────────────
# If /admin/classes returns empty (academy not marked PAID), provide the map
# manually as a JSON object: course_name (lowercase) → class ID
# AKADEMO_CLASS_MAP={"biofarmacia":"cls_abc123","farmacología":"cls_def456"}

# ── Dry run ──────────────────────────────────────────────────────────────────
# Set to 1 to test the script without making any FTP or API calls
# DRY_RUN=1
